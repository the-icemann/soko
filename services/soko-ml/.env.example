# ── Service Ports ─────────────────────────────────────────────────────────────
PRICE_SERVICE_PORT=8001
REC_SERVICE_PORT=8002
GATEWAY_PORT=8000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PRICE_REQUEST_TOPIC=soko.price.requests
KAFKA_PRICE_RESULT_TOPIC=soko.price.results
KAFKA_TRANSACTION_TOPIC=soko.transactions
KAFKA_INTERACTION_TOPIC=soko.interactions
KAFKA_ML_EVENTS_TOPIC=soko.ml.events
KAFKA_DLQ_TOPIC=soko.dlq

# ── ML Config ─────────────────────────────────────────────────────────────────
MODEL_DIR=/app/models
FARMERS_DATA_PATH=/app/data/raw/farmers.csv
BUYERS_DATA_PATH=/app/data/raw/buyers.csv
PRICE_CACHE_TTL_SECONDS=86400
REC_CACHE_TTL_SECONDS=3600
DEFAULT_TOP_N=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SERVICE_NAME=soko-ml
