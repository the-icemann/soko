# Copy this to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

aws_region       = "af-south-1"
environment      = "prod"
instance_type    = "t3.xlarge"
ec2_key_name     = "soko-prod-key"          # Name of key pair in AWS EC2 console
allowed_ssh_cidr = "YOUR_IP/32"             # Replace with your home/office IP
domain_name      = "yourdomain.com"         # Leave empty string "" if no domain yet
alert_email      = "andrewssuubi@gmail.com"
github_repo      = "the-icemann/soko"
